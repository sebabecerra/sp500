  "devDependencies": {
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
