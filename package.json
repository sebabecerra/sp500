{
  "name": "sp500-market-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "extract:wikipedia": "node ./scripts/extract-wikipedia.mjs",
    "extract:yahoo": "node ./scripts/extract-yahoo-quotes.mjs",
